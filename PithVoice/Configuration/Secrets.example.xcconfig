// Secrets.example.xcconfig
//
// Copy to Secrets.xcconfig (gitignored) and fill in real values.
// Never commit Secrets.xcconfig itself.
//
// Apple Developer team that signs the app.
DEVELOPMENT_TEAM =

// App Store Connect API access (used by fastlane and ASC API scripts).
// .p8 file lives at /Users/vassiliyshmigirivov/Apple_apps/AuthKey_<KEY_ID>.p8 (gitignored).
APP_STORE_CONNECT_API_KEY_ID =
APP_STORE_CONNECT_API_KEY_ISSUER_ID =

// fastlane match — empty until match is initialised. Xcode-managed signing
// is sufficient for development on the studio Mac.
MATCH_GIT_URL =
MATCH_PASSWORD =

# SwiftFormat config — Pith

--swiftversion 5.10
--indent 4
--maxwidth 140
--linebreaks lf
--semicolons never
--commas always
--trailingclosures
--self remove
--patternlet inline
--stripunusedargs closure-only
--header strip
--ifdef no-indent
--xcodeindentation enabled
--wraparguments before-first
--wrapparameters before-first
--wrapcollections before-first
--wrapconditions after-first
--wrapreturntype if-multiline
--closingparen balanced
--funcattributes prev-line
--typeattributes prev-line
--storedvarattrs same-line
--computedvarattrs prev-line
--marktypes always
--markextensions always
--organizetypes class,struct,enum,extension
--ranges no-space
--operatorfunc spaced
--allman false
--decimalgrouping 3,5
--binarygrouping 4,8
--hexgrouping 4,8
--octalgrouping 4,8
--exponentcase lowercase
--hexliteralcase uppercase

--exclude **/.build,**/DerivedData,**/Resources,**/Generated,Pith/Configuration/Secrets*.xcconfig

--enable isEmpty
--enable strongOutlets
--enable redundantSelf
--enable redundantParens
--enable redundantReturn
--enable redundantType
--enable redundantVoidReturnType
--enable trailingCommas
--enable wrapMultilineStatementBraces
--enable blankLinesBetweenScopes
--enable blankLinesAtStartOfScope
--enable blankLinesAtEndOfScope

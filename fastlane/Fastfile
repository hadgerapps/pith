default_platform(:ios)

PROJECT = "PithVoice.xcodeproj"
SCHEME = "PithVoice"
APP_BUNDLE_ID = "com.hadger.pith"
TEAM_ID = "X243T6N439"
APP_ID = "6770544476"
ASC_KEY_ID = ENV["APP_STORE_CONNECT_API_KEY_ID"] || "9P9W84M53Z"
ASC_ISSUER_ID = ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"] || "3030c9a1-732a-427c-a680-1de04cd5005d"
ASC_KEY_PATH = File.expand_path("AuthKey_#{ASC_KEY_ID}.p8", "../..")
WORKSPACE_ROOT = File.expand_path("..", __dir__)

platform :ios do
  desc "Generate the Xcode project from project.yml"
  lane :generate do
    sh("cd #{WORKSPACE_ROOT.shellescape} && PATH=\"#{WORKSPACE_ROOT}/.tooling/bin:$PATH\" xcodegen generate")
  end

  desc "Build and run all tests"
  lane :test do
    generate
    run_tests(
      project: PROJECT,
      scheme: SCHEME,
      device: "iPhone 17 Pro",
      clean: true,
      code_coverage: true
    )
  end

  desc "Upload IPA + metadata to TestFlight (beta)"
  lane :beta do
    generate
    api_key = app_store_connect_api_key(
      key_id: ASC_KEY_ID,
      issuer_id: ASC_ISSUER_ID,
      key_filepath: ASC_KEY_PATH,
      duration: 1200,
      in_house: false
    )
    increment_build_number(
      xcodeproj: PROJECT,
      build_number: latest_testflight_build_number(
        app_identifier: APP_BUNDLE_ID,
        api_key: api_key
      ).to_i + 1
    )
    build_app(
      project: PROJECT,
      scheme: SCHEME,
      export_method: "app-store",
      output_directory: "build",
      clean: true
    )
    upload_to_testflight(
      api_key: api_key,
      app_identifier: APP_BUNDLE_ID,
      skip_waiting_for_build_processing: true,
      changelog: File.read("metadata/review_information/notes.txt").strip
    )
  end

  desc "Push metadata + screenshots (no binary) to App Store Connect"
  lane :metadata do
    api_key = app_store_connect_api_key(
      key_id: ASC_KEY_ID,
      issuer_id: ASC_ISSUER_ID,
      key_filepath: ASC_KEY_PATH,
      duration: 1200,
      in_house: false
    )
    upload_to_app_store(
      api_key: api_key,
      app_identifier: APP_BUNDLE_ID,
      skip_binary_upload: true,
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end

  desc "Beta + metadata, then leave the Submit click to the human"
  lane :release do
    beta
    metadata
    UI.success("Build + metadata uploaded. Click Submit in App Store Connect when ready.")
  end
end
